# Reddit API credentials (free read-only access)
# Register at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=news-credibility-checker/0.1 by your_username

# Source toggles (set to "false" to disable a collector)
ENABLE_REDDIT=true
ENABLE_WIKIPEDIA=true
ENABLE_WEB=true
ENABLE_HACKERNEWS=true

# HTTP / network settings
REQUEST_TIMEOUT=10
MAX_RETRIES=2

# Collection limits
REDDIT_MAX_RESULTS=20
WIKIPEDIA_MAX_RESULTS=3
WEB_MAX_RESULTS=10
HN_MAX_RESULTS=15

# Scoring weights (must sum to 1.0)
WEIGHT_CORROBORATION=0.35
WEIGHT_CONTRADICTION=0.30
WEIGHT_SOURCE_QUALITY=0.20
WEIGHT_RECENCY=0.15

# Credibility thresholds
LABEL_TRUE_THRESHOLD=60
LABEL_FALSE_THRESHOLD=40

# Reddit quality heuristics
REDDIT_MIN_SCORE=5

# Hacker News quality heuristics (no API key required)
HN_MIN_POINTS=10

# Wikipedia quality discount (0.0–1.0, lower = less influence)
WIKIPEDIA_QUALITY_WEIGHT=0.3
